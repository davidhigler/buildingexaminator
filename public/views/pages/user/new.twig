    <h3 class="header">{{ 'new user'|trans()|capitalize }}</h3>
    <form id="newuser">
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">man</i>
                <select id="user_type_select">
                    <option value="Dobro">{{ 'dobro'|trans()|capitalize }}</option>
                    <option value="Owner">{{ 'owner'|trans()|capitalize }}</option>
                    <option value="Contractor">{{ 'contractor'|trans()|capitalize }}</option>
                    <option value="Subcontractor">{{ 'subcontractor'|trans()|capitalize }}</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">email</i>
                <input id="email" name="email" type="email" required aria-required="true" minlength="3" maxlength="128" placeholder="{{ 'email'|trans()|capitalize }}">
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">fingerprint</i>
                <input id="password" name="password" type="password" required aria-required="true" minlength="3" maxlength="128" placeholder="{{ 'password'|trans()|capitalize }}">
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">refresh</i>
                <input id="confirmpassword" name="confirmpassword" type="password" required aria-required="true" minlength="3" maxlength="128" placeholder="{{ 'repeat password'|trans()|capitalize }}">
            </div>
        </div>
        <div class="row">
            <div class="col s6">
                <button class="btn" name="create" type="submit">
                    <i class="material-icons">person_add</i><span class="button-content hide-on-small-only">{{ 'create'|trans()|capitalize }}</span>
                </button>
            </div>
            <div class="col s6">
                <button class="btn right" name="cancel">
                    <i class="material-icons left">cancel</i><span class="button-content hide-on-small-only">{{ 'cancel'|trans()|capitalize }}</span>
                </button>
            </div>
        </div>
    </form>
