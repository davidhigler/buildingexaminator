    <h3 class="header">{{ 'edit user'|trans()|capitalize }}</h3>
    <form id="edituser">
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix disabled">numbers</i>
                <input disabled id="id" name="id" type="text" placeholder="{{ 'id'|trans()|capitalize }}" value="{{ id }}">
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">email</i>
                <input id="email" name="email" type="email" required aria-required="true" minlength="3" maxlength="128" placeholder="{{ 'email'|trans()|capitalize }}" value="{{ email }}">
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">fingerprint</i>
                <input id="password" name="password" type="password" required aria-required="true" minlength="3" maxlength="128" placeholder="{{ 'password'|trans()|capitalize }}">
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">refresh</i>
                <input id="confirmpassword" name="confirmpassword" type="password" required aria-required="true" minlength="3" maxlength="128" placeholder="{{ 'confirm password'|trans()|capitalize }}">
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <div class="switch">
                    <label>
                        Admin
                        <input type="checkbox" id="adminrole"{% if admin %} checked="checked"{% endif %}>
                        <span class="lever"></span>
                    </label>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col s6">
                <button type="submit" class="btn" name="save">
                    <i class="material-icons left">save</i>{{ 'save'|trans()|capitalize }}
                </button>
            </div>
            <div class="col s6">
                <button class="btn right" name="cancel">
                    <i class="material-icons left">cancel</i>{{ 'cancel'|trans()|capitalize }}
                </button>
            </div>
        </div>
    </form>