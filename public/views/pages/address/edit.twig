    <h3 class="header">{{ 'edit address'|trans()|capitalize }}</h3>
    <form id="editbuildingaddress">
        <div class="row">
            <div class="col s12">
                <p>
                    {{ addressdata.publicSpace.name }} {{ addressdata.houseNumber }}{% if addressdata.addition %} {{ addressdata.addition }}{% endif %}<br />
                    {{ addressdata.zipcode }} {{ addressdata.city.name }}
                </p>
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">view_comfortable</i>
                <select id="block" name="block">
                    {% for block in blocks %}
                        <option value="{{ block.id }}"{% if addressdata.block.id == block.id %} selected{% endif %}>{{ block.name }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">home_work</i>
                <select id="buildingtype" name="buildingtype">
                    {% for buildingtype in buildingtypes %}
                        <option value="{{ buildingtype.id }}"{% if addressdata.buildingType.id == buildingtype.id %} selected{% endif %}>{{ buildingtype.name }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">vtw</i>
                <select id="vtw" name="vtw">
                    {% for vtw in vtws %}
                        <option value="{{ vtw.id }}"{% if addressdata.vtw.id == vtw.id %} selected{% endif %}>{{ vtw.code }} - {{ vtw.typeDescription }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">qr_code_2</i>
                <input id="rentalunitnumber" name="rentalunitnumber" type="text" value="{{ addressdata.rentalUnitNumber|default('') }}">
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">explore</i>
                <select id="orientation" name="orientation">
                    <option value="n" data-icon="/images/directions/n.png"{% if addressdata.orientation == 'n' %} selected{% endif %}>{{ 'north'|trans()|capitalize }}</option>
                    <option value="nne" data-icon="/images/directions/nne.png"{% if addressdata.orientation == 'nne' %} selected{% endif %}>{{ 'north'|trans()|capitalize }} {{ 'north'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="ne" data-icon="/images/directions/ne.png"{% if addressdata.orientation == 'ne' %} selected{% endif %}>{{ 'north'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="nee" data-icon="/images/directions/nee.png"{% if addressdata.orientation == 'nee' %} selected{% endif %}>{{ 'north'|trans()|capitalize }} {{ 'east'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="e" data-icon="/images/directions/e.png"{% if addressdata.orientation == 'e' %} selected{% endif %}>{{ 'east'|trans()|capitalize }}</option>
                    <option value="see" data-icon="/images/directions/see.png"{% if addressdata.orientation == 'see' %} selected{% endif %}>{{ 'south'|trans()|capitalize }} {{ 'east'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="se" data-icon="/images/directions/se.png"{% if addressdata.orientation == 'se' %} selected{% endif %}>{{ 'south'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="sse" data-icon="/images/directions/sse.png"{% if addressdata.orientation == 'sse' %} selected{% endif %}>{{ 'south'|trans()|capitalize }} {{ 'south'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="s" data-icon="/images/directions/s.png"{% if addressdata.orientation == 's' %} selected{% endif %}>{{ 'south'|trans()|capitalize }}</option>
                    <option value="ssw" data-icon="/images/directions/ssw.png"{% if addressdata.orientation == 'ssw' %} selected{% endif %}>{{ 'south'|trans()|capitalize }} {{ 'south'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                    <option value="sw" data-icon="/images/directions/sw.png"{% if addressdata.orientation == 'sw' %} selected{% endif %}>{{ 'south'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                    <option value="sww" data-icon="/images/directions/sww.png"{% if addressdata.orientation == 'sww' %} selected{% endif %}>{{ 'south'|trans()|capitalize }} {{ 'west'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                    <option value="w" data-icon="/images/directions/w.png"{% if addressdata.orientation == 'w' %} selected{% endif %}>{{ 'west'|trans()|capitalize }}</option>
                    <option value="nww" data-icon="/images/directions/nww.png"{% if addressdata.orientation == 'nww' %} selected{% endif %}>{{ 'north'|trans()|capitalize }} {{ 'west'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                    <option value="nw" data-icon="/images/directions/nw.png"{% if addressdata.orientation == 'nw' %} selected{% endif %}>{{ 'north'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                    <option value="nnw" data-icon="/images/directions/nnw.png"{% if addressdata.orientation == 'nnw' %} selected{% endif %}>{{ 'north'|trans()|capitalize }} {{ 'north'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <p>
                    <i class="material-icons prefix">house_money</i>
                    <label>
                        <input id="daeb" name="daeb" type="checkbox"{% if addressdata.daeb %} checked{% endif %}>
                        <span>Daeb</span>
                    </label>
                </p>
            </div>
        </div>
        <div class="row">
            <div class="col s6">
                <button type="submit" class="btn" name="save">
                    <i class="material-icons left">save</i><span class="button-content hide-on-small-only">{{ 'save'|trans()|capitalize }}</span>
                </button>
            </div>
            <div class="col s6">
                <button class="btn right" name="cancel">
                    <i class="material-icons left">cancel</i><span class="button-content hide-on-small-only">{{ 'cancel'|trans()|capitalize }}</span>
                </button>
            </div>
        </div>
    </form>
