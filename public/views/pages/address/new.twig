    <h3 class="header">{{ 'new address'|trans()|capitalize }}</h3>
    <form id="newbuildingaddress">
        <div class="row">
            <div class="col s12">
                <p>{{ 'By filling in the zipcode, housenumber and addition the rest of the information about this new address will be fetched by appropiate external services.'|trans() }}</p>
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">zipcode</i>
                <input id="zipcode" name="zipcode" type="text" placeholder="{{ 'zipcode'|trans()|capitalize }}">
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">123</i>
                <input id="housenumber" name="housenumber" type="text" placeholder="{{ 'house number'|trans()|capitalize }}">
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">abc</i>
                <input id="addition" name="addition" type="text" placeholder="{{ 'addition'|trans()|capitalize }}">
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">view_comfortable</i>
                <select id="block" name="block">
                    <option value="" disabled selected hidden>{{ 'block'|trans()|capitalize }}</option>
                    {% for block in blocks %}
                    <option value="{{ block.id }}">{{ block.name }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">home_work</i>
                <select id="buildingtype" name="buildingtype">
                    <option value="" disabled selected hidden>{{ 'building type'|trans()|capitalize }}</option>
                    {% for buildingtype in buildingtypes %}
                    <option value="{{ buildingtype.id }}">{{ buildingtype.name }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">vtw</i>
                <select id="vtw" name="vtw">
                    <option value="" disabled selected hidden>{{ 'VTW'|trans()|capitalize }}</option>
                    {% for vtw in vtws %}
                    <option value="{{ vtw.id }}">{{ vtw.code }} - {{ vtw.typeDescription }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">qr_code_2</i>
                <input id="rentalunitnumber" name="rentalunitnumber" type="text" placeholder="{{ 'rental unit number'|trans()|capitalize }}">
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <i class="material-icons prefix">explore</i>
                <select id="orientation" name="orientation">
                    <option value="" disabled selected hidden>{{ 'orientation façade'|trans()|capitalize }}</option>
                    <option value="n" data-icon="/images/directions/n.png">{{ 'north'|trans()|capitalize }}</option>
                    <option value="nne" data-icon="/images/directions/nne.png">{{ 'north'|trans()|capitalize }} {{ 'north'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="ne" data-icon="/images/directions/ne.png">{{ 'north'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="nee" data-icon="/images/directions/nee.png">{{ 'north'|trans()|capitalize }} {{ 'east'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="e" data-icon="/images/directions/e.png">{{ 'east'|trans()|capitalize }}</option>
                    <option value="see" data-icon="/images/directions/see.png">{{ 'south'|trans()|capitalize }} {{ 'east'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="se" data-icon="/images/directions/se.png">{{ 'south'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="sse" data-icon="/images/directions/sse.png">{{ 'south'|trans()|capitalize }} {{ 'south'|trans()|capitalize }} {{ 'east'|trans()|capitalize }}</option>
                    <option value="s" data-icon="/images/directions/s.png">{{ 'south'|trans()|capitalize }}</option>
                    <option value="ssw" data-icon="/images/directions/ssw.png">{{ 'south'|trans()|capitalize }} {{ 'south'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                    <option value="sw" data-icon="/images/directions/sw.png">{{ 'south'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                    <option value="sww" data-icon="/images/directions/sww.png">{{ 'south'|trans()|capitalize }} {{ 'west'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                    <option value="w" data-icon="/images/directions/w.png">{{ 'west'|trans()|capitalize }}</option>
                    <option value="nww" data-icon="/images/directions/nww.png">{{ 'north'|trans()|capitalize }} {{ 'west'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                    <option value="nw" data-icon="/images/directions/nw.png">{{ 'north'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                    <option value="nnw" data-icon="/images/directions/nnw.png">{{ 'north'|trans()|capitalize }} {{ 'north'|trans()|capitalize }} {{ 'west'|trans()|capitalize }}</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="input-field col s12">
                <p>
                    <i class="material-icons prefix">house_money</i>
                    <label>
                        <input id="daeb" name="daeb" type="checkbox">
                        <span>Daeb</span>
                    </label>
                </p>
            </div>
        </div>
        <div class="row">
            <div class="col s6">
                <button class="btn" name="create" type="submit">
                    <i class="material-icons left">add_view_quilt</i><span class="button-content hide-on-small-only">{{ 'create'|trans()|capitalize }}</span>
                </button>
            </div>
            <div class="col s6">
                <button class="btn right" name="cancel">
                    <i class="material-icons left">cancel</i><span class="button-content hide-on-small-only">{{ 'cancel'|trans()|capitalize }}</span>
                </button>
            </div>
        </div>
    </form>
