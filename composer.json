{
    "name": "davidhigler/first-time-symfony",
    "description": "Learning Symfony 5",
    "type": "project",
    "require": {
        "doctrine/annotations": "^1.13",
        "symfony/asset": "^5.2",
        "symfony/config": "^5.2",
        "symfony/console": "^5.2",
        "symfony/debug-bundle": "^5.2",
        "symfony/dependency-injection": "^5.2",
        "symfony/dotenv": "^5.2",
        "symfony/error-handler": "^5.2",
        "symfony/flex": "^1.13",
        "symfony/framework-bundle": "^5.2",
        "symfony/http-foundation": "^5.2",
        "symfony/http-kernel": "^5.2",
        "symfony/routing": "^5.2",
        "symfony/skeleton": "^5.2",
        "symfony/yaml": "^5.2"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "authors": [
        {
            "name": "David C. Higler",
            "email": "davidhigler@gmail.com"
        }
    ],
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    }
}
