{
    "name": "davidhigler/buildingexaminator",
    "description": "Building Examinator",
    "license": "proprietary",
    "type": "project",
    "authors": [
        {
            "name": "David C. Higler",
            "email": "davidhigler@gmail.com"
        },
        {
            "name": "Reiny Griemink",
            "email": "rgriemink@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-curl": "*",
        "ext-iconv": "*",
        "ext-intl": "*",
        "ext-mysqli": "*",
        "ext-mysqlnd": "*",
        "ext-openssl": "*",
        "ext-redis": "*",
        "ext-sqlite3": "*",
        "ext-xml": "*",
        "ext-zip": "*",
        "composer/package-versions-deprecated": "~1.11.99",
        "doctrine/annotations": "~2.0.2",
        "doctrine/doctrine-bundle": "~2.15.1",
        "doctrine/doctrine-migrations-bundle": "~3.4.2",
        "doctrine/orm": "~3.5.2",
        "guzzlehttp/guzzle": "^7.10",
        "jms/translation-bundle": "~2.6.0",
        "knplabs/knp-paginator-bundle": "~6.8.1",
        "league/flysystem": "~3.30.0",
        "phpdocumentor/reflection-docblock": "~5.6.3",
        "predis/predis": "~3.0.1",
        "ramsey/uuid": "~4.9.0",
        "scheb/2fa-google-authenticator": "^7.12",
        "symfony/asset": "~6.4.24",
        "symfony/console": "~6.4.25",
        "symfony/dotenv": "~6.4.24",
        "symfony/expression-language": "~6.4.24",
        "symfony/flex": "~2.8.2",
        "symfony/form": "~6.4.25",
        "symfony/framework-bundle": "~6.4.25",
        "symfony/http-client": "~6.4.25",
        "symfony/intl": "~6.4.25",
        "symfony/lock": "~6.4.24",
        "symfony/mailer": "~6.4.25",
        "symfony/mime": "~6.4.24",
        "symfony/monolog-bundle": "~3.10.0",
        "symfony/notifier": "~6.4.25",
        "symfony/process": "~6.4.25",
        "symfony/property-access": "~6.4.25",
        "symfony/property-info": "~6.4.24",
        "symfony/proxy-manager-bridge": "~6.4.24",
        "symfony/rate-limiter": "~6.4.24",
        "symfony/runtime": "~6.4.24",
        "symfony/security-bundle": "~6.4.25",
        "symfony/serializer": "~6.4.25",
        "symfony/string": "~6.4.25",
        "symfony/translation": "~6.4.24",
        "symfony/twig-bundle": "~6.4.24",
        "symfony/validator": "~6.4.25",
        "symfony/web-link": "~6.4.24",
        "symfony/yaml": "~6.4.25",
        "twig/extra-bundle": "~3.21.0",
        "twig/twig": "^3.22",
        "willdurand/js-translation-bundle": "~7.0.0"
    },
    "require-dev": {
        "ext-xdebug": "*",
        "doctrine/doctrine-fixtures-bundle": "~4.1.0",
        "phpunit/phpunit": "^12.3",
        "rector/rector": "~2.1.4",
        "zircote/swagger-php": "~5.1.4",
        "symfony/maker-bundle": "~1.64.0",
        "symfony/phpunit-bridge": "~7.3.3",
        "symfony/browser-kit": "~6.4.24",
        "symfony/css-selector": "~6.4.24",
        "symfony/debug-bundle": "~6.4.13",
        "symfony/stopwatch": "~6.4.24",
        "symfony/web-profiler-bundle": "~6.4.25"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "src/",
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "6.4.*",
            "docker": false
        },
        "runtime": {
            "class": "Symfony\\Component\\Runtime\\GenericRuntime"
        }
    }
}
