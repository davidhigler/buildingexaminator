{% extends "main.twig" %}

{% block content %}
    <div class="row">
        <div class="col s2">
            <div class="center-align app-logo"><i class="large material-icons">library_books</i></div>
            <h2 class="center-align">Menu</h2>
        </div>
        <div class="col s10">
            <h2 class="center-align">Housingstocks</h2>
            <table>
                <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Action</th>
                </tr>
                </thead>
                <tbody>
                {% for housingstock in housingstocks %}                        <tr>
                    <td>{{ housingstock.code }}</td>
                    <td>{{ housingstock.name }}</td>
                    <td>
                        <button class="btn" name="edit">Edit</button>
                        <button data-target="modaldelete" class="btn modal-trigger" name="delete">Delete</button>
                    </td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        <div id="modaldelete" class="modal">
            <div class="modal-content">
                <h4>Are you sure?</h4>
                <p>Do you know for sure that you want to delete this?</p>
            </div>
            <div class="modal-footer">
                <a href="#!" class="modal-close btn">No</a>
                <a href="#!" class="modal-close btn">Yes</a>
            </div>
        </div>
    </div>
{% endblock %}