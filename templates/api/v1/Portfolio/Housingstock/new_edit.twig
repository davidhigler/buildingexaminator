{% extends "main.twig" %}

{% block content %}
    <h3 class="header">Housingstock</h3>
    {{ form_start(form, {'action': '', 'attr': {'class': 'col s12'}}) }}
        <div class="row">
            <div class="input-field col s6">
                {{ form_widget(form.code) }}
                {{ form_label(form.code) }}
            </div>
        </div>
        <div class="row">
            <div class="input-field col s6">
                {{ form_widget(form.name) }}
                {{ form_label(form.name) }}
            </div>
        </div>
        <div class="row">
            <div class="input-field col s6">
                {{ form_widget(form.description, {'attr': {'class': 'materialize-textarea'}}) }}
                {{ form_label(form.description) }}
            </div>
        </div>
        <div class="row">
            <div class="col s6">
                {{ form_widget(form.save, {'attr': {'class': 'btn'}}) }}
            </div>
        </div>
    {{ form_end(form, {render_rest: false}) }}
{% endblock %}