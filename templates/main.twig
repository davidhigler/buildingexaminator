<!DOCTYPE html>
<html lang="nl_NL">
    <head>
        <title>{{ title }}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
        <link type="text/css" rel="stylesheet" href="/assets/materialize/css/materialize.min.css" media="screen,projection"/>
        <link type="text/css" rel="stylesheet" href="/css/main.css"/>
        <script type="text/javascript" src="/assets/jquery/jquery-3.6.0.min.js"></script>
        <script type="text/javascript" src="/js/main.js"></script>
    </head>
    <body>
        <ul class="sidenav sidenav-fixed">
            <li id="menu-logo">
                <div id="logo-dia"></div>
            </li>
{% for route in routes %}
            <li><a href="{{ route.path }}">{{ route.title }}</a></li>
{% endfor %}
        </ul>
        <ul id="slide-out" class="sidenav">
{% for route in routes %}
            <li><a href="{{ route.path }}">{{ route.title }}</a></li>
{% endfor %}
        </ul>
        <nav class="top-nav">
            <div class="container">
                <div class="nav-wrapper">
                    <div class="row">
                        <div class="col s10 m10 l9 offset-s2 offset-m2 offset-l3">
                            <h1 class="header">{{ title }}</h1>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
        <div class="container">
            <a href="#" data-target="slide-out" class="top-nav sidenav-trigger hide-on-large-only">
                <i class="material-icons">menu</i>
            </a>
        </div>
        <div class="container">
            <div class="row">
                <div class="col s12 m12 l9 offset-l3">
{% block content %}
{% endblock %}
                </div>
            </div>
        </div>
        <script type="text/javascript" src="/assets/materialize/js/materialize.min.js"></script>
    </body>
</html>
